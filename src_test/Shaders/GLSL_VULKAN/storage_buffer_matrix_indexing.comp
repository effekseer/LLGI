#version 430
layout(local_size_x = 1, local_size_y = 1, local_size_z = 1) in;

struct MatrixIndexingRecord
{
    mat4 Clip;
    mat4x3 Transform;
    vec4 Local;
    uint Row;
    uint Flags;
    uvec2 Padding;
};

struct MatrixIndexingOutput
{
    vec4 Clip;
    vec3 Indexed;
    uint Checksum;
};

layout(set = 2, binding = 1, std430) readonly buffer Records
{
    layout(row_major) MatrixIndexingRecord _data[];
} Records_1;

layout(set = 2, binding = 0, std430) buffer Output
{
    MatrixIndexingOutput _data[];
} Output_1;

void _main(uvec3 dtid)
{
    MatrixIndexingRecord record;
    record.Clip = Records_1._data[dtid.x].Clip;
    record.Transform = Records_1._data[dtid.x].Transform;
    record.Local = Records_1._data[dtid.x].Local;
    record.Row = Records_1._data[dtid.x].Row;
    record.Flags = Records_1._data[dtid.x].Flags;
    record.Padding = Records_1._data[dtid.x].Padding;
    vec3 world = record.Transform * record.Local;
    vec4 clip = vec4(world, 1.0) * record.Clip;
    uint row = record.Row & 3u;
    uint nextRow = (row + 1u) & 3u;
    MatrixIndexingOutput _output;
    _output.Clip = clip;
    _output.Indexed = record.Transform[row] + (record.Transform[nextRow] * 0.25);
    _output.Checksum = (record.Flags ^ record.Row) ^ floatBitsToUint(record.Local.w);
    Output_1._data[dtid.x].Clip = _output.Clip;
    Output_1._data[dtid.x].Indexed = _output.Indexed;
    Output_1._data[dtid.x].Checksum = _output.Checksum;
}

void main()
{
    uvec3 dtid = gl_GlobalInvocationID;
    uvec3 param = dtid;
    _main(param);
}

